# Auto detect text files and perform LF normalization
* text=auto

# HTML
*.html text eol=lf

# CSS
*.css text eol=lf

# JavaScript
*.js text eol=lf

# Images — treat as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# PDF
*.pdf binary
